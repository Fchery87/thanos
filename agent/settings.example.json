{
  "lastChangelogVersion": "0.75.5",
  "packages": [
    "npm:@victor-software-house/pi-curated-themes",
    "npm:context-mode",
    "..",
    {
      "source": "git:github.com/rytswd/pi-agent-extensions",
      "extensions": [
        "!direnv/*",
        "fetch/*",
        "notify/*",
        "permission-gate/*",
        "questionnaire/*",
        "slow-mode/*",
        "!stash/*",
        "statusline/*"
      ]
    },
    "npm:pi-subagents",
    "npm:pi-web-access"
  ],
  "theme": "brogrammer",
  "defaultThinkingLevel": "high",
  "treeFilterMode": "default",
  "quietStartup": true
}
