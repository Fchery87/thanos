{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "chrome-devtools-mcp",
      "args": [],
      "env": []
    },
    "context7": {
      "type": "stdio",
      "command": "context7-mcp",
      "args": ["--api-key", "<YOUR_CONTEXT7_API_KEY>"],
      "env": []
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "mcp-server-sequential-thinking",
      "args": [],
      "env": []
    },
    "convex-mcp": {
      "type": "stdio",
      "command": "convex",
      "args": ["mcp", "start"],
      "env": []
    },
    "mgrep": {
      "type": "stdio",
      "command": "mgrep",
      "args": ["mcp"],
      "env": []
    },
    "exa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "<YOUR_EXA_API_KEY>",
        "ENABLED_TOOLS": "web_search_exa,web_search_advanced_exa,crawling_exa,get_code_context_exa"
      }
    },
    "neon": {
      "type": "sse",
      "url": "https://mcp.neon.tech/mcp"
    },
    "stitch": {
      "type": "sse",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "<YOUR_GOOGLE_STITCH_API_KEY>"
      }
    }
  }
}
