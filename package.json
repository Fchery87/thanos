{
  "name": "thanos-install",
  "version": "0.1.0",
  "description": "Thanos — Pi harness config layer. One-command installer.",
  "type": "module",
  "bin": {
    "thanos-install": "./scripts/npm-install.mjs"
  },
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "ci": "bun run typecheck && bun run lint && bun run test"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "eslint": "^9.39.4",
    "typebox": "^1.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "js-yaml": "^4.3.0",
    "ws": "^8.21.0"
  }
}
